{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main window on every platform.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:path:default",
    "log:default",
    "os:default",
    "fs:default",
    "http:default",
    "dialog:default",
    "notification:default",
    "shell:allow-open",
    "store:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ],
  "platforms": ["linux", "macOS", "windows", "android", "iOS"]
}
