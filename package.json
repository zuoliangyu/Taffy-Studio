{
  "name": "taffy-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Taffy Studio — cross-platform AI workstation (Tauri 2 + React). Chat, knowledge, MCP, agents — five platforms.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "ios:init": "tauri ios init",
    "ios:dev": "tauri ios dev",
    "ios:build": "tauri ios build",
    "dev:desktop": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 desktop",
    "dev:android": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 android",
    "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 windows",
    "build:linux": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 linux",
    "build:android": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 android",
    "build:all": "powershell -ExecutionPolicy Bypass -File scripts/build.ps1 all",
    "ci:local": "powershell -ExecutionPolicy Bypass -File scripts/ci-local.ps1",
    "mac:dev": "bash scripts/dev-mac.sh",
    "mac:build": "bash scripts/build-mac.sh",
    "mac:ci": "bash scripts/ci-local.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tesseract.js"
    ]
  }
}
