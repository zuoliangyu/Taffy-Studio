# ============================================================
# Dependencies
# ============================================================
node_modules/
.pnpm-store/

# ============================================================
# Build outputs   —   build matrix: linux · windows · mac · ios · android · web · docker
# ============================================================
# Vite frontend build (intermediate; embedded into the desktop/web binaries).
dist/
dist-ssr/
*.tsbuildinfo
node_modules/.tmp/

# Rust build cache — huge, regenerated per machine.
# This is a Cargo workspace, so EVERY crate (src-tauri, taffy-core, taffy-web)
# builds into the single workspace-root ./target. Windows (.exe/.msi) and macOS
# (.app/.dmg) bundles land in target/release/bundle/ — already covered here.
# src-tauri/target/ is the legacy pre-workspace path; nothing writes there
# anymore, kept only so old checkouts stay clean.
# NOTE: Cargo.lock IS committed (this is an app, not a library).
target/
src-tauri/target/

# Tauri generated native mobile projects (Android/iOS scaffolding from
# `tauri android init` / `tauri ios init`). Regenerated on demand; drifts
# between machines / Xcode / NDK versions.
src-tauri/gen/

# All packaged release artifacts go under one roof (scripts/build-*.{ps1,sh}):
#   dist-out/linux/    (.deb .AppImage .rpm)
#   dist-out/android/  (.apk .aab)
#   dist-out/ios/      (.ipa)
#   dist-out/web/      (single-file taffy-web[.exe])
#   (docker -> image in the local daemon, no repo file to ignore)
# One folder to ignore; any transfer zip you drop inside is covered too.
dist-out/

# ============================================================
# Internal-only docs — planning / WIP, not for the public repo.
# Kept on disk locally; never tracked.
# ============================================================
docs/internal/

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# Env / secrets
# ============================================================
.env
.env.local
.env.*.local
*.local

# Signing keys & certificates — NEVER commit these.
keys/
*.keystore
*.jks
*.p12
*.pfx
*.mobileprovision
*.cer

# Tauri updater private signing key (the .pub one is fine to commit).
*.tauri.key
*.tauri.key.enc

# `scripts/setup-updater.{ps1,sh}` writes the freshly-generated private key
# here. Nothing else should ever live in this directory.
secrets/

# ============================================================
# Editors / IDEs
# ============================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
*.bak
*.orig

# ============================================================
# OS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Test / coverage
# ============================================================
coverage/
.nyc_output/

